{
  "name": "@source-wire/contracts",
  "version": "0.0.0",
  "private": false,
  "description": "Public Source-Wire contract package skeleton for agent-first memory systems.",
  "keywords": [
    "agent-memory",
    "ai-agents",
    "contracts",
    "json-schema",
    "mcp",
    "second-brain",
    "source-graph",
    "validation"
  ],
  "homepage": "https://github.com/DanielJD1216/Source-Wire#readme",
  "bugs": {
    "url": "https://github.com/DanielJD1216/Source-Wire/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/DanielJD1216/Source-Wire.git"
  },
  "type": "module",
  "license": "UNLICENSED",
  "publishConfig": {
    "access": "restricted"
  },
  "bin": {
    "source-wire": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./schemas/project-context-pack": "./schemas/project-context-pack.schema.json",
    "./schemas/second-brain-v1": "./schemas/second-brain-v1.schema.json",
    "./schemas/chat-export-message": "./schemas/chat-export-message.schema.json"
  },
  "files": [
    "dist",
    "docs",
    "examples",
    "schemas",
    "README.md"
  ],
  "scripts": {
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "examples:typecheck": "tsc -p examples/typescript/tsconfig.json --noEmit",
    "build": "tsc -p tsconfig.json",
    "test": "npm run typecheck && npm run validate:fixtures && npm run verify:schema-exports && npm run cli:smoke && npm run examples:typecheck",
    "validate:fixtures": "npm run build && node dist/validate-fixtures.js",
    "verify:schema-exports": "npm run build && node scripts/verify-schema-exports.mjs",
    "cli:smoke": "npm run build && node scripts/cli-smoke.mjs",
    "consumer:smoke": "node scripts/consumer-smoke.mjs",
    "examples:installed-smoke": "node scripts/examples-installed-smoke.mjs",
    "docs:links": "node scripts/check-doc-links.mjs",
    "safety:scan": "node scripts/public-safety-scan.mjs",
    "ci:check": "npm run typecheck && npm run build && npm test && npm run validate:fixtures && npm run verify:schema-exports && npm run cli:smoke && npm run safety:scan",
    "release:gate": "node scripts/release-gate.mjs",
    "package:dry-run": "npm run build && node scripts/package-dry-run.mjs",
    "package:content-smoke": "node scripts/package-content-smoke.mjs",
    "publish:readiness": "npm run ci:check && npm run release:gate && npm run package:dry-run && npm run consumer:smoke && npm run package:content-smoke && npm run examples:installed-smoke && npm run docs:links && npm run safety:scan"
  },
  "devDependencies": {
    "@types/node": "^26.0.1",
    "typescript": "^5.5.0"
  }
}
