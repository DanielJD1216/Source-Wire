{
  "name": "@source-wire/contracts",
  "version": "0.0.0",
  "private": false,
  "description": "Public Source-Wire contract package skeleton for agent-first memory systems.",
  "keywords": [
    "agent-memory",
    "ai-agents",
    "contracts",
    "json-schema",
    "mcp",
    "second-brain",
    "source-graph",
    "validation"
  ],
  "homepage": "https://github.com/DanielJD1216/Source-Wire#readme",
  "bugs": {
    "url": "https://github.com/DanielJD1216/Source-Wire/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/DanielJD1216/Source-Wire.git"
  },
  "type": "module",
  "license": "Apache-2.0",
  "publishConfig": {
    "access": "restricted"
  },
  "bin": {
    "source-wire": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./schemas/project-context-pack": "./schemas/project-context-pack.schema.json",
    "./schemas/second-brain-v1": "./schemas/second-brain-v1.schema.json",
    "./schemas/chat-export-message": "./schemas/chat-export-message.schema.json",
    "./schemas/owner-hosted-api-mcp-boundary": "./schemas/owner-hosted-api-mcp-boundary.schema.json"
  },
  "files": [
    "CONTRIBUTING.md",
    "dist",
    "docs",
    "examples",
    "SECURITY.md",
    "schemas",
    "SUPPORT.md",
    "README.md"
  ],
  "scripts": {
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "examples:typecheck": "tsc -p examples/typescript/tsconfig.json --noEmit",
    "build": "tsc -p tsconfig.json",
    "test": "npm run typecheck && npm run validate:fixtures && npm run verify:schema-exports && npm run cli:smoke && npm run examples:typecheck",
    "validate:fixtures": "npm run build && node dist/validate-fixtures.js",
    "verify:schema-exports": "npm run build && node scripts/verify-schema-exports.mjs",
    "cli:smoke": "npm run build && node scripts/cli-smoke.mjs",
    "consumer:smoke": "node scripts/consumer-smoke.mjs",
    "examples:installed-smoke": "node scripts/examples-installed-smoke.mjs",
    "minimal-runtime:smoke": "npm run build && node examples/minimal-runtime/minimal-runtime-smoke.mjs",
    "runtime-boundary:smoke": "node examples/runtime-boundary/synthetic-boundary-smoke.mjs",
    "runtime-boundary:installed-smoke": "node scripts/runtime-boundary-installed-smoke.mjs",
    "runtime-boundary:diagnostics-smoke": "node scripts/runtime-boundary-diagnostics-smoke.mjs",
    "reviewer:smoke": "node scripts/reviewer-first-pass-smoke.mjs",
    "readiness:report": "node scripts/readiness-report.mjs",
    "docs:links": "node scripts/check-doc-links.mjs",
    "docs:command-setup": "node scripts/check-command-doc-setup.mjs",
    "repository:metadata": "node scripts/repository-metadata-boundary.mjs",
    "repository:live-github": "node scripts/live-github-surface.mjs",
    "registry:live-npm": "node scripts/live-npm-registry-boundary.mjs",
    "pull-request:boundary": "node scripts/pull-request-boundary.mjs",
    "share:audit": "node scripts/share-audit.mjs",
    "intake:boundary": "node scripts/intake-boundary.mjs",
    "safety:scan": "node scripts/public-safety-scan.mjs",
    "claims:scan": "node scripts/public-claim-boundary-scan.mjs",
    "package:required-paths": "node scripts/check-package-required-paths.mjs",
    "ci:markers": "node scripts/check-ci-markers.mjs",
    "ci:markers:smoke": "node scripts/ci-markers-smoke.mjs",
    "license:rehearsal": "node scripts/license-approval-rehearsal.mjs",
    "license:decision-record": "node scripts/license-decision-record.mjs",
    "license:approval-request": "node scripts/license-approval-request.mjs",
    "license:implementation-plan": "node scripts/license-implementation-plan.mjs",
    "license:history-boundary": "node scripts/license-history-boundary.mjs",
    "legal:packet": "node scripts/legal-review-packet.mjs",
    "owner:launch-checklist": "node scripts/owner-launch-checklist.mjs",
    "owner:license-preflight": "node scripts/owner-license-preflight.mjs",
    "owner:decision-intake": "node scripts/owner-license-decision-intake.mjs",
    "owner:decision-workflow": "node scripts/owner-decision-workflow.mjs",
    "world:readiness": "node scripts/world-share-readiness.mjs",
    "launch:decision-status": "node scripts/launch-decision-status.mjs",
    "release:implementation-plan": "node scripts/release-implementation-plan.mjs",
    "release:review": "node scripts/release-review.mjs",
    "release:approval-request": "node scripts/release-approval-request.mjs",
    "release:candidate-readiness": "node scripts/release-candidate-readiness.mjs",
    "ci:check": "npm run typecheck && npm run build && npm test && npm run validate:fixtures && npm run verify:schema-exports && npm run cli:smoke && npm run minimal-runtime:smoke && npm run runtime-boundary:smoke && npm run safety:scan && npm run claims:scan",
    "release:gate": "node scripts/release-gate.mjs",
    "package:dry-run": "npm run build && node scripts/package-dry-run.mjs",
    "package:content-smoke": "node scripts/package-content-smoke.mjs",
    "publish:readiness": "npm run ci:check && npm run release:gate && npm run release:implementation-plan && npm run release:review && npm run release:approval-request && npm run release:candidate-readiness && npm run license:rehearsal && npm run license:decision-record && npm run license:approval-request && npm run license:implementation-plan && npm run license:history-boundary && npm run legal:packet && npm run owner:launch-checklist && npm run owner:license-preflight && npm run owner:decision-intake && npm run owner:decision-workflow && npm run world:readiness && npm run launch:decision-status && npm run share:audit && npm run intake:boundary && npm run repository:metadata && npm run pull-request:boundary && npm run package:required-paths && npm run package:dry-run && npm run consumer:smoke && npm run package:content-smoke && npm run examples:installed-smoke && npm run runtime-boundary:installed-smoke && npm run runtime-boundary:diagnostics-smoke && npm run readiness:report && npm run docs:links && npm run docs:command-setup && npm run safety:scan && npm run claims:scan && npm run ci:markers:smoke"
  },
  "devDependencies": {
    "@types/node": "^26.0.1",
    "typescript": "^5.5.0"
  }
}
